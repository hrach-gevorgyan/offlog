<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Resolves the single combined widget's VIEW intents back to
                 this same activity (B37 redesign, 2026-07-09) — quickadd
                 (B10), agenda (B20, now also the widget's "brief" tap
                 target), focus, dashboard, and project?id=<id> (still used
                 by in-app deep links even though the dedicated project-list
                 widget was removed). One filter, multiple <data> hosts;
                 "project" deliberately has no android:path/pathPattern
                 constraint so its ?id= query string isn't part of the
                 manifest match, just read in JS via new URL(url). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.offlog.app" android:host="quickadd" />
                <data android:scheme="com.offlog.app" android:host="agenda" />
                <data android:scheme="com.offlog.app" android:host="focus" />
                <data android:scheme="com.offlog.app" android:host="dashboard" />
                <data android:scheme="com.offlog.app" android:host="project" />
            </intent-filter>
        </activity>

        <!-- exported="true": the widget picker/launcher is a different app
             and needs to bind this provider — the APPWIDGET_UPDATE broadcast
             itself is already OS-protected regardless of this flag. -->
        <receiver android:name=".OffologWidgetProvider" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider" android:resource="@xml/offlog_widget_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Track E: capacitor-zeroconf's mDNS discovery ("Find my computer" in
         Settings -> Sync) acquires a WiFi multicast lock so mDNS broadcast
         packets actually reach the app; Android drops multicast traffic
         to apps by default otherwise. The plugin itself
         (node_modules/capacitor-zeroconf) doesn't declare this permission
         in its own manifest, so it has to live here instead; missing it
         doesn't crash, it just makes discovery silently find nothing. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Local notifications: task reminders -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- App Lock: biometric unlock, opt-in fast path alongside the PIN -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
</manifest>
