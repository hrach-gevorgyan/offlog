<?xml version="1.0" encoding="utf-8"?>
<!-- v5.4.2 bug (owner-reported live testing, 2026-07-21, with a screenshot
     showing "FOCUS" wrapped one letter per line): android:previewLayout
     was pointed at the real @layout/widget_offlog, whose root is
     match_parent — for the WIDGET PICKER specifically, that gets
     measured against minWidth/minHeight (110x110dp, correct for the real
     2x2 on-device footprint, see offlog_widget_info.xml's own comment on
     why that must never change again), squishing the wrap_content card
     down to a near-square canvas the Focus pill's text can't fit in
     horizontally. This is a copy of widget_offlog.xml with ONLY the root
     changed to a fixed size instead of match_parent — previewLayout is a
     fully separate resource from initialLayout, so this has zero effect
     on the real widget's on-device size; it only gives the picker's
     thumbnail render enough room to lay out the same content without
     constraint-driven wrapping. Keep the two files' inner content in
     sync by hand if the widget's design ever changes.
     v5.4.5 follow-up (owner feedback, 2026-07-21): the card itself is
     wrap_content, so a bigger frame just adds empty space AROUND it —
     the picker scales the whole frame down to thumbnail size, so more
     dead space makes the card look SMALLER once scaled, not bigger.
     Tightened from 200x170dp to 185x155dp (close to the card's natural
     ~173x149dp content size) so it fills nearly the whole frame instead
     of floating in the middle of it. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_preview_root"
    android:layout_width="185dp"
    android:layout_height="155dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="140dp"
        android:layout_gravity="center"
        android:background="@drawable/widget_background"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/widget_pill_bg"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">
            <ImageView
                android:layout_width="19dp"
                android:layout_height="19dp"
                android:src="@drawable/ic_widget_focus"
                android:layout_marginEnd="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_action_focus"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/widget_button_bg">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textColor="@color/colorWidgetText"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/widget_button_bg">
                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_grid" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
