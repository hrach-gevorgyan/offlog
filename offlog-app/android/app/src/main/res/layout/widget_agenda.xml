<?xml version="1.0" encoding="utf-8"?>
<!-- Read-only "what's due soon" widget (ROADMAP.md B20). Up to 3 fixed rows
     (RemoteViews has no real list/adapter support without a RemoteViewsService,
     which is overkill for "3 rows, refreshed whenever the JS side pushes new
     data") — AgendaWidgetProvider hides unused rows via View.GONE. The whole
     widget is one PendingIntent target (opens Agenda), same pattern as
     QuickAddWidgetProvider/widget_quick_add.xml. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/agenda_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_agenda_label"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:alpha="0.75"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/agenda_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView
            android:id="@+id/agenda_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/agenda_due_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:alpha="0.7"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agenda_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView
            android:id="@+id/agenda_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/agenda_due_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:alpha="0.7"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agenda_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView
            android:id="@+id/agenda_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/agenda_due_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:alpha="0.7"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
