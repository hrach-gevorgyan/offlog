<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!-- Real AndroidX SplashScreen API attributes — the previous version of
         this theme only set the legacy `android:background`, which
         Theme.SplashScreen (the androidx.core.splashscreen compat theme)
         doesn't read at all. Without windowSplashScreenBackground/
         windowSplashScreenAnimatedIcon set, the system falls back to a
         plain white background with a default-scaled launcher icon on
         Android 12+ (API 31+, which targetSdk 36 puts nearly every real
         device on) regardless of what drawable/splash.png contains — that
         mismatch against the app's charcoal/indigo brand is what read as a
         rough, unbranded launch. postSplashScreenTheme hands control back to
         the normal app theme once the splash dismisses.
         windowSplashScreenAnimatedIcon originally pointed at @mipmap/
         ic_launcher_foreground — owner-reported live testing, 2026-07-20:
         "logo is shrunk". Root cause: that asset already has the 66%-of-
         canvas safe-zone padding baked in that adaptive *launcher* icons
         need, and the SplashScreen API applies its own additional inset on
         top of whatever icon it's given, assuming the same convention —
         stacking two rounds of padding. Now points at a dedicated
         drawable/splash_icon.png (resources/generate-splash.cjs), mark at
         92% of canvas so it lands at a normal size after the API's inset. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorPrimaryDark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>