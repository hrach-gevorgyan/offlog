<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="colorPrimary">#5457e0</color>
    <color name="colorPrimaryDark">#181a20</color>
    <color name="colorAccent">#5457e0</color>

    <!-- B37/B48 — widget palette, matched to app.css's tokens. This file
         holds the LIGHT set (used whenever the OS isn't in dark mode); the
         dark set lives in values-night/colors.xml. Originally hardcoded to
         the dark palette unconditionally (widgets render outside the
         app's own in-app theme setting, so they should follow the
         *system* light/dark setting instead — owner feedback, 2026-07-13).
         Keep both files in sync with app.css's :root / body.dark blocks if
         the palette ever changes; see docs/TECH.md's Theme System table
         for the source of truth.
         colorWidgetBg/colorWidgetSurface deliberately deviate from
         app.css's exact surface/bg light token values (#FFFFFF/#F6F7F9) —
         owner feedback 2026-07-17 that the widget's pure white read as
         too stark against a real home-screen wallpaper. Warmed to a
         slight cream tint; dark mode (values-night) is unaffected and
         intentionally still the exact app.css values. -->
    <color name="colorWidgetBg">#FBF8F2</color>      <!-- warm cream, not app.css's exact surface token -->
    <color name="colorWidgetSurface">#F1EDE3</color> <!-- flat tint one step off colorWidgetBg -->
    <color name="colorWidgetAccent">#5457E0</color>  <!-- app.css accent token, light -->
    <color name="colorWidgetText">#1F2937</color>    <!-- app.css text token, light -->
    <color name="colorWidgetMuted">#4B5563</color>   <!-- app.css muted token, light -->
</resources>
