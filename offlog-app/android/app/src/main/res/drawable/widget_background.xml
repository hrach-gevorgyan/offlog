<?xml version="1.0" encoding="utf-8"?>
<!-- B37 — was a flat colorPrimary (accent) fill, which read as "just a
     solid-color card" across all 3 widgets. Now matches the app's own
     dark surface + hairline border (see colors.xml's colorWidget* group,
     sourced from app.css's body.dark tokens). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/colorWidgetBg" />
    <stroke android:width="1dp" android:color="@color/colorWidgetBorder" />
    <corners android:radius="20dp" />
</shape>
