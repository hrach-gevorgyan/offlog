<?xml version="1.0" encoding="utf-8"?>
<!-- Static Android App Shortcut (long-press the launcher icon) — jumps
     straight into QuickAdd instead of the full app. See MainActivity.java
     and App.svelte's 'offlogQuickAdd' listener. ROADMAP.md B10. -->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="quick_add"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_quickadd_short"
        android:shortcutLongLabel="@string/shortcut_quickadd_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.offlog.app"
            android:targetClass="com.offlog.app.MainActivity"
            android:data="com.offlog.app://quickadd" />
    </shortcut>
</shortcuts>
