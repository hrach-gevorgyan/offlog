<?xml version="1.0" encoding="utf-8"?>
<!-- minWidth/minHeight reverted to the original 110x110dp / 2x2 cells
     (owner-reported, 2026-07-17): the previous attempt to fix the widget
     picker's clipped preview by growing these to 200x160dp/4x2 also grew
     the REAL on-device widget footprint to 3x3 — the picker preview issue
     is cosmetic (previewLayout, API 31+, rendering this RemoteViews layout
     shrunk into a small thumbnail frame), the real 2x2 placement was
     already correct and shouldn't have been changed to chase it. Left as
     a known, accepted preview-thumbnail quirk rather than distorting the
     real widget size again. maxResizeWidth/maxResizeHeight stay dropped —
     both are inert when resizeMode="none" (no resize handles are ever
     shown), so removing them was a real cleanup, unrelated to the size
     revert above. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_offlog"
    android:previewLayout="@layout/widget_offlog"
    android:widgetCategory="home_screen"
    android:description="@string/widget_offlog_description"
    android:resizeMode="none" />
