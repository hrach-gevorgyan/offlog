# Copy this file to keystore.properties (same folder) and fill in the real
# values to build a real Play-Store-signed release locally. NEVER commit
# the filled-in keystore.properties or the .keystore file itself -- both
# are already gitignored (see ../.gitignore).
#
# storeFile is relative to this app/ directory -- e.g. if your keystore
# lives at C:\Users\you\Offlog-signing\offlog-release.keystore, either copy
# it into this folder, or use an absolute path here instead.
#
# storePassword and keyPassword are the same value for a PKCS12 keystore
# (the format `keytool -genkeypair -storetype PKCS12` produces) -- PKCS12
# doesn't support separate store/key passwords.

storeFile=offlog-release.keystore
storePassword=REPLACE_ME
keyAlias=offlog
keyPassword=REPLACE_ME
