{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Offlog",
  "version": "4.24.0",
  "identifier": "com.offlog.app",
  "build": {
    "frontendDist": "../../offlog-app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Offlog",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "visible": false,
        "backgroundColor": "#181a20"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../vendor/couchdb-win": "couchdb"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
