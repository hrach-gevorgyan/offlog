{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Offlog",
  "version": "5.7.4",
  "identifier": "com.offlog.app",
  "build": {
    "frontendDist": "../../offlog-app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Offlog",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "dragDropEnabled": false,
        "visible": false,
        "backgroundColor": "#181a20"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; connect-src 'self' http://*:*; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../vendor/couchdb-win": "couchdb"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://example.invalid/offlog/latest.json"
      ],
      "pubkey": "PLACEHOLDER_NOT_A_REAL_KEY_REPLACE_AT_C1_WITH_cargo_tauri_signer_generate_OUTPUT"
    }
  }
}
